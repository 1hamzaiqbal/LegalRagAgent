# --- Active provider (set LLM_PROVIDER to switch) ---
# Run `uv run python llm_config.py` to see all providers with rate limits.
LLM_PROVIDER=deepseek

# --- DeepSeek (pay-per-use, no TPM cap — recommended for multi-step runs) ---
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# --- Google AI Studio (gemma-3-27b-it, 14.4K RPD free but 15K tokens/min cap) ---
# GOOGLE_API_KEY=your-google-ai-studio-key-here

# --- Groq (multiple models, free tier has low TPM limits) ---
# GROQ_API_KEY=gsk_your-groq-key-here

# --- OpenRouter (free tier, weekly token limits) ---
# OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# --- Cerebras ---
# CEREBRAS_API_KEY=csk-your-cerebras-key-here

# --- Ollama (local, no key needed) ---
# No API key required. Set LLM_PROVIDER=ollama.

# --- Embedding model (default: Alibaba-NLP/gte-large-en-v1.5) ---
# EMBEDDING_MODEL=Alibaba-NLP/gte-large-en-v1.5

# --- Source-diverse retrieval (split MBE/wex vs caselaw pools, default off) ---
# SOURCE_DIVERSE_RETRIEVAL=0

# --- Offline HuggingFace model loading (skip network checks after first download) ---
# HF_HUB_OFFLINE=1

# --- Legacy fallback (used if LLM_PROVIDER is not set or unknown) ---
# LLM_BASE_URL=https://api.deepseek.com
# LLM_API_KEY=your-key-here
# LLM_MODEL=deepseek-chat
